# =============================================================
# QC Tracker — Environment variables
# Copy file ini menjadi `.env` lalu isi nilainya.
# =============================================================

# --- Public ---
# Public URL, used for OG Image when running nuxt generate
NUXT_PUBLIC_SITE_URL=

# --- Database ---
# Path ke file SQLite (dipakai drizzle.config.ts dan runtime).
DB_FILE_NAME=file:./data/local.db

# --- Better Auth ---
# Secret untuk signing cookie/session. Generate dengan:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# (JANGAN pakai placeholder di production!)
BETTER_AUTH_SECRET=please-replace-with-a-strong-random-secret-min-32-chars

# Base URL aplikasi (origin). Dipakai untuk callback & CORS auth.
BETTER_AUTH_URL=http://localhost:3000

# --- Seed admin (opsional) ---
# Dipakai oleh `pnpm db:seed:admin`. Tidak wajib di .env karena
# sudah ada default — hanya set bila ingin override default.
# ADMIN_NAME=QC Tracker Admin
# ADMIN_EMAIL=admin@qtrack.local
# ADMIN_PASSWORD=z
    